{
  "name": "between-us",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "expo start",
    "start:light": "NODE_OPTIONS=--max-old-space-size=2048 EXPO_NO_TELEMETRY=1 EXPO_USE_FAST_RESOLVER=1 EXPO_PUBLIC_LIGHTWEIGHT_DEV=1 expo start --host lan --max-workers 2",
    "android": "expo run:android",
    "android:light": "NODE_OPTIONS=--max-old-space-size=2048 EXPO_NO_TELEMETRY=1 EXPO_USE_FAST_RESOLVER=1 EXPO_PUBLIC_LIGHTWEIGHT_DEV=1 expo run:android",
    "ios": "expo run:ios",
    "ios:light": "NODE_OPTIONS=--max-old-space-size=2048 EXPO_NO_TELEMETRY=1 EXPO_USE_FAST_RESOLVER=1 EXPO_PUBLIC_LIGHTWEIGHT_DEV=1 expo run:ios",
    "web": "expo start --web",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "validate": "node scripts/validateDeployment.cjs --platform all",
    "validate:ios": "node scripts/validateDeployment.cjs --platform ios",
    "validate:android": "node scripts/validateDeployment.cjs --platform android",
    "bump:patch": "node scripts/bumpVersion.cjs patch",
    "bump:minor": "node scripts/bumpVersion.cjs minor",
    "bump:major": "node scripts/bumpVersion.cjs major",
    "lint": "npx expo lint App.js assets components config context hooks mocks navigation plugins screens services utils __tests__ scripts -- --no-error-on-unmatched-pattern",
    "pre-deploy": "npm test && npm run validate:ios"
  },
  "dependencies": {
    "@expo-google-fonts/dm-serif-display": "^0.4.2",
    "@expo-google-fonts/lato": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@noble/hashes": "^2.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.11.0",
    "@sentry/react-native": "~7.13.0",
    "@supabase/supabase-js": "^2.93.3",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-sensors": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^9.7.5",
    "react-native-purchases-ui": "^9.7.5",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-shared-group-preferences": "^1.1.24",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-worklets": "0.5.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.10",
    "anser": "^2.3.5",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "babel-preset-expo": "^54.0.10",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import-x": "4.15.0",
    "expo-module-scripts": "^5.0.8",
    "fast-check": "^4.5.3",
    "jest": "~29.7.0",
    "react-native-svg-transformer": "^1.5.3",
    "react-refresh": "^0.18.0",
    "react-test-renderer": "^19.1.0",
    "typescript": "^5.9.3"
  }
}

{
  "expo": {
    "name": "MySky",
    "slug": "mysky",
    "scheme": "mysky",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#020817"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "assets/**",
      "content/**"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.brittany.mysky",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.brittany.mysky"
    },
    "description": "MySky — private self-reflection journal for mood, sleep, dreams, patterns, and inner insight.",
    "extra": {
      "appName": "MySky",
      "eas": {
        "projectId": "YOUR-MYSKY-PROJECT-ID"
      }
    },
    "newArchEnabled": false,
    "plugins": [
      "expo-font",
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo-transparent.png",
          "backgroundColor": "#020817",
          "imageWidth": 220
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/YOUR-MYSKY-PROJECT-ID"
    }
  }
}

{
  "expo": {
    "name": "Between Us",
    "slug": "between-us",
    "scheme": "betweenus",
    "version": "1.0.17",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "assets/**",
      "content/**"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.brittany.betweenus",
      "buildNumber": "10",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is required to scan your partner’s QR code for secure pairing.",
        "NSPhotoLibraryUsageDescription": "Photo library access lets you add photos to love notes, journal entries, and memories.",
        "NSMicrophoneUsageDescription": "Microphone access lets you record encrypted voice notes for your partner.",
        "NSFaceIDUsageDescription": "Between Us uses Face ID to protect your private content with biometric authentication.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": [
              "E174.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          }
        ],
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeDeviceID",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAnalytics"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeCrashData",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePerformanceData",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeOtherDiagnosticData",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.brittany.betweenus"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "description": "Between Us — Where closeness deepens. A private space for thriving couples to deepen connection, intimacy, and meaningful moments.",
    "extra": {
      "appName": "Between Us",
      "tagline": "Where closeness deepens.",
      "eas": {
        "projectId": "ab5503ed-b0de-4bf0-aabc-6c46d0c00ec1"
      }
    },
    "experiments": {},
    "newArchEnabled": true,
    "plugins": [
      "./plugins/withSentryAlwaysOutOfDate.cjs",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-camera",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a0614"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "between-us",
          "organization": "brittany-hornick"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#A30F11",
          "image": "./assets/logo-transparent.png",
          "imageWidth": 220
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ab5503ed-b0de-4bf0-aabc-6c46d0c00ec1"
    }
  }
}
